APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=api_logs
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache Configuration
# The cache driver to use: redis, memcached, database, or file
CACHE_STORE=redis
# CACHE_PREFIX=

# Redis Configuration
# The Redis client library (phpredis or predis)
REDIS_CLIENT=phpredis
# Redis host address for cache storage
REDIS_HOST=127.0.0.1
# Redis password for authentication (null if no password required)
REDIS_PASSWORD=null
# Redis port number
REDIS_PORT=6379
# Redis database number for cache
REDIS_CACHE_DB=1

# Memcached Configuration
# Memcached host address (used if CACHE_STORE=memcached)
MEMCACHED_HOST=127.0.0.1
# Memcached port number
MEMCACHED_PORT=11211

# API Cache Configuration
# Time-to-live for cached API responses in seconds (default: 3600 = 1 hour)
API_CACHE_TTL=3600

# Log Retention Configuration
# Number of days to retain API request logs before deletion (default: 30)
LOG_RETENTION_DAYS=30

# External API Configuration
# Weather API base URL
WEATHER_API_URL=https://api.weather.com
# Weather API authentication key
WEATHER_API_KEY=your_weather_api_key_here

# News API base URL
NEWS_API_URL=https://api.news.com
# News API authentication key
NEWS_API_KEY=your_news_api_key_here

# HTTP timeout for external API requests in seconds (default: 10)
EXTERNAL_API_TIMEOUT=10

# Cache Warming Configuration
# Comma-separated list of endpoints to pre-populate when running cache:warm-api command
CACHE_WARM_ENDPOINTS=weather/current,news/headlines,stocks/trending

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
